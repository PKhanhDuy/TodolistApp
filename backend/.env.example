# Sao chep file nay thanh .env va dien thong tin thuc te.

# ==== Database cloud (vi du Neon - PostgreSQL) ====
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>/<db>?sslmode=require
SPRING_DATASOURCE_USERNAME=your-username
SPRING_DATASOURCE_PASSWORD=your-password

# Che do sinh schema: none | validate | update | create | create-drop
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ==== JWT ====
# Secret PHAI dai >= 32 ky tu. Doi thanh chuoi ngau nhien manh trong production!
APP_JWT_SECRET=change-this-dev-secret-please-use-at-least-32-characters
# Thoi han token tinh bang mili-giay (mac dinh 1 ngay = 86400000)
APP_JWT_EXPIRATION_MS=86400000
